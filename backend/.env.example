# Copy this file to backend/.env and replace only the placeholder value.
# Never commit backend/.env or share the API key in chat, screenshots, or logs.
DASHSCOPE_API_KEY=replace-with-your-api-key

QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus

DATABASE_PATH=data/app.sqlite3
UPLOAD_DIR=data/uploads

# Optional. Set this to enable OCR fallback for scanned PDFs.
# Example Windows path:  E:\aaaxz\Tesseract-OCR\tesseract.exe
# Example Linux path:     /usr/bin/tesseract
TESSERACT_EXECUTABLE=
OCR_LANGUAGE=chi_sim+eng

# Privacy controls (all optional, defaults preserve current behaviour).
# PRIVACY_PII_SCRUB=1     -> strip obvious PII patterns (email/phone/ID numbers)
#                             from PDF/OCR text before it is sent to the model.
# PRIVACY_LOCAL_ONLY=1    -> refuse to call the remote model and return offline
#                             answers; only the local arXiv + PDF pipeline runs.
# PRIVACY_DATA_TTL_DAYS=0 -> auto-delete database rows older than N days on
#                             startup (0 disables the cleanup).
