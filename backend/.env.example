# Copy this file to backend/.env before starting the backend.
# Never commit backend/.env or share API keys in chat, screenshots, logs, or docs.
DASHSCOPE_API_KEY=replace-with-your-api-key

# Main model for long-form academic reading, comparison, framework building,
# topic guidance, and artifact-card generation.
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus

# Fast model for intent classification and first-message session titles.
# Leave ROUTER_API_KEY empty to reuse DASHSCOPE_API_KEY.
ROUTER_API_KEY=
ROUTER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ROUTER_MODEL=deepseek-v4-flash
ROUTER_DISABLE_THINKING=1

# Local SQLite database and uploaded PDF storage.
# Keep these paths inside the project unless you intentionally move local data.
DATABASE_PATH=data/app.sqlite3
UPLOAD_DIR=data/uploads

# Optional. Set this to enable OCR fallback for scanned PDFs.
# Example Windows path:  E:\aaaxz\Tesseract-OCR\tesseract.exe
# Example Linux path:     /usr/bin/tesseract
TESSERACT_EXECUTABLE=
OCR_LANGUAGE=chi_sim+eng

# Optional. Usually unnecessary during local development because Vite proxies
# /api requests to the backend. If you call the backend directly from another
# local browser origin, list it here.
# Example: http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOWED_ORIGINS=

# Privacy controls (all optional, defaults preserve current behaviour).
# PRIVACY_PII_SCRUB=1     -> strip obvious PII patterns (email/phone/ID numbers)
#                             from PDF/OCR text before it is sent to the model.
# PRIVACY_LOCAL_ONLY=1    -> refuse to call the remote model and return offline
#                             answers; only the local arXiv + PDF pipeline runs.
# PRIVACY_DATA_TTL_DAYS=0 -> auto-delete database rows older than N days on
#                             startup (0 disables the cleanup).
